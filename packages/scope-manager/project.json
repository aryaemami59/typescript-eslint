{
  "name": "scope-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "packages/scope-manager",
  "sourceRoot": "packages/scope-manager/src",
  "targets": {
    "test": {
      "executor": "@nx/vite:test"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "cwd": "{projectRoot}",
        "commands": [
          { "command": "tsc -p tsconfig.build.json --noEmit" },
          { "command": "tsc -p tsconfig.spec.json --noEmit" }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
