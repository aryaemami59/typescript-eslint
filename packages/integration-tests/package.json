{
  "name": "@typescript-eslint/integration-tests",
  "private": true,
  "scripts": {
    "format": "prettier --write \"./**/*.{ts,mts,cts,tsx,js,mjs,cjs,jsx,json,md,css}\" --ignore-path ../../.prettierignore",
    "lint": "npx nx lint",
    "test": "vitest --run --no-coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@jest/types": "29.6.3",
    "ncp": "*",
    "tmp": "*",
    "tsx": "*",
    "vitest": "^2.1.3"
  }
}
