Options: { "fixStyle": "separate-type-imports" }

import type { Foo } from 'Foo';
import type Bar from 'Bar';
type T = Foo;
const x: Bar = 1;
en.
const x: import('Bar') = 1;
         ~~~~~~~~~~~~~ `import()` type annotations are forbidden.
. Use `import type`.
type T = Foo;
const x: Bar = 1;
 T = Foo;
const x: Bar = 1;
